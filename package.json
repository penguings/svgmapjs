{
	"devDependencies": {
		"@playwright/test": "^1.57.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@testing-library/dom": "^10.4.1",
		"@types/node": "^25.0.8",
		"cross-env": "^10.1.0",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"jsdoc": "^4.0.5",
		"jsts": "^2.12.1",
		"playwright": "^1.57.0",
		"rollup": "^4.55.1"
	},
	"name": "svgmaplv0.2",
	"description": "Modular SVGMap.js alpha",
	"version": "0.0.1",
	"private": true,
	"main": "SVGMapLv0.1.js",
	"workspaces": [
		"packages/*",
		"packages/extensions/*"
	],
	"scripts": {
		"test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest",
		"report": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest --coverage",
		"e2e": "npx playwright test",
		"build": "node scripts/prepare-package-dists.mjs && rollup -c",
		"docs:api": "jsdoc --lenient -c jsdoc.json"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/svgmap/svgMapLv0.2.git"
	},
	"author": "",
	"license": "MPL-2.0 (See LICENSE file for details)",
	"bugs": {
		"url": "https://github.com/svgmap/svgMapLv0.2/issues"
	},
	"homepage": "https://github.com/svgmap/svgMapLv0.2#readme",
	"type": "module",
	"jest": {
		"verbose": false,
		"testEnvironment": "jsdom",
		"testMatch": [
			"<rootDir>/tests/unittest/*.test.js",
			"<rootDir>/tests/unittest/**.test.js"
		],
		"testPathIgnorePatterns": [
			"<rootDir>/node_modules/",
			"<rootDir>/tests/e2e/"
		]
	}
}
